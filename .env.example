# Frontend (copy to frontend/.env.local for local dev)
VITE_API_BASE_URL=https://<api-id>.execute-api.ap-southeast-1.amazonaws.com/v1
VITE_CLOUDFRONT_DOMAIN=https://<distribution-id>.cloudfront.net

# Backend (set as Lambda environment variables via Terraform)
DYNAMODB_TABLE_NAME=hdb-cats-sightings
S3_BUCKET_NAME=hdb-cats-images
CLOUDFRONT_DOMAIN=https://<distribution-id>.cloudfront.net
AWS_REGION=ap-southeast-1
